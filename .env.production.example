# 复制为 .env.production 后填写。这个文件不要提交真实密钥。

# 服务端口，Docker 内部固定 3000。宿主机端口在 docker-compose.yml ports 里控制。
ERP_PORT=3000

# 旧钉钉群 Webhook，仅用于兼容历史调用；库存日报改用下方企业应用机器人。
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 钉钉企业内部应用登录。Session Secret 请使用至少 32 字节随机值。
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_REDIRECT_URI=https://erp.lttlt.top/api/auth/dingtalk/callback
DINGTALK_SESSION_SECRET=
# 逗号分隔 unionId/openId；留空代表企业应用范围内用户均可登录。
DINGTALK_ALLOWED_USER_IDS=
# 逗号分隔 unionId/openId；管理员可导入退货表和配置摄像头。
DINGTALK_ADMIN_USER_IDS=

# 库存报告确认催办。云端常驻服务每小时 @ 指定人，直到本人 @机器人 回复“收到”。
DINGTALK_REMINDER_ENABLED=false
DINGTALK_REMINDER_TARGET_NAME=陈奇慧
# 填钉钉通讯录 userid，不是 unionId/openId。
DINGTALK_REMINDER_TARGET_USER_ID=
# 已加入目标群、启用了 Stream 消息接收的企业应用机器人名称；不要填仅发送消息的 Webhook 群机器人。
DINGTALK_REMINDER_BOT_NAME=AI自动化机器人
# 企业应用机器人的 RobotCode；默认复用 DINGTALK_CLIENT_ID，显式填写可避免应用调整时歧义。
DINGTALK_REMINDER_ROBOT_CODE=
# 可发送“取消”的管理员 userid，多个使用英文逗号分隔。
DINGTALK_REMINDER_CANCEL_USER_IDS=
# 首次可留空；收到目标人在群里的确认后会记录群会话。若机器人加入多个群，建议显式填写。
DINGTALK_REMINDER_CONVERSATION_ID=
DINGTALK_REMINDER_INTERVAL_MS=3600000

# 库存预警默认阈值。SKU 单独设置优先。
LOW_STOCK_THRESHOLD=10

# 菜鸟账号密码只给本地自动化备用。生产服务器不建议跑菜鸟滑块自动化。
CAINIAO_USERNAME=
CAINIAO_PASSWORD=

# 拆包视频取证。视频文件仅保存在 NAS，云端仅保存索引和校验值。
# 与 NAS 的 nas-video-service/.env 使用同一个高强度随机值。
UNPACK_NAS_SHARED_SECRET=
VIDEO_NAS_COMMAND_URL=https://video.lttlt.top/v1/commands
