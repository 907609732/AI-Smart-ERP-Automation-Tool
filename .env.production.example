# 复制为 .env.production 后填写。这个文件不要提交真实密钥。

# 服务端口，Docker 内部固定 3000。宿主机端口在 docker-compose.yml ports 里控制。
ERP_PORT=3000

# 钉钉机器人。使用你之前配置过的 webhook 和加签。
DINGTALK_WEBHOOK=
DINGTALK_SECRET=

# 库存预警默认阈值。SKU 单独设置优先。
LOW_STOCK_THRESHOLD=10

# 菜鸟账号密码只给本地自动化备用。生产服务器不建议跑菜鸟滑块自动化。
CAINIAO_USERNAME=
CAINIAO_PASSWORD=

# 拆包视频取证。视频文件仅保存在 NAS，云端仅保存索引和校验值。
# 与 NAS 的 nas-video-service/.env 使用同一个高强度随机值。
UNPACK_NAS_SHARED_SECRET=
VIDEO_NAS_COMMAND_URL=https://video.lttlt.top/v1/commands
